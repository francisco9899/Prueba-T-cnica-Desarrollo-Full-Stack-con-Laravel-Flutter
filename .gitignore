# Ignorar dependencias de Composer (Backend)
vendor/

# Ignorar dependencias de Node.js (si las hay para el frontend web de Laravel)
node_modules/

# Ignorar cachés de Laravel
bootstrap/cache/
storage/app/public/ # A menos que quieras subir assets públicos específicos
storage/framework/sessions/
storage/logs/*.log

# Ignorar archivos de entorno
.env
.env.*

# Ignorar archivos de sistema operativo
.DS_Store
Thumbs.db

# Ignorar archivos de compilación de Flutter
build/
.dart_tool/
# Opcional: Ignorar la carpeta de dependencias nativas si prefieres que Flutter las genere
# ios/Pods/
# android/.gradle/
